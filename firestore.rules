rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'jefri@bizgroup-id.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---

    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'userId', 'userName', 'userPosition', 'timestamp'])
        && data.keys().size() <= 6 // text, userId, userName, userPosition, timestamp, optional attachments
        && data.text is string && data.text.size() <= 1000
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.userPosition is string && data.userPosition.size() <= 100
        && (data.timestamp is string || data.timestamp is timestamp)
        && (!data.keys().hasAny(['attachments']) || data.attachments is list);
    }

    function isValidDailyRecord(data) {
      return data.keys().hasAll(['date', 'timestamp', 'ob', 'cg', 'weather', 'productivity', 'pa'])
        && data.date is string && data.date.size() <= 20
        && data.timestamp is number
        && data.ob is map && data.ob.actual is number
        && data.cg is map && data.cg.actual is number
        && data.productivity is map
        && data.pa is map;
    }

    function isValidSystemUpdate(data) {
      return data.keys().hasAll(['title', 'timestamp'])
        && data.title is string && data.title.size() <= 200
        && (data.timestamp is string || data.timestamp is timestamp)
        && (!data.keys().hasAny(['content']) || data.content is string)
        && (!data.keys().hasAny(['version']) || data.version is string);
    }

    function isValidPresence(data) {
      return data.keys().hasAll(['uid', 'status', 'lastActive'])
        && data.uid == request.auth.uid
        && data.status in ['Online', 'Offline']
        && (data.lastActive == request.time || data.lastActive is timestamp || data.lastActive is string)
        && (!data.keys().hasAny(['name']) || (data.name is string && data.name.size() <= 100))
        && (!data.keys().hasAny(['position']) || (data.position is string && data.position.size() <= 100))
        && (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() <= 100))
        && (!data.keys().hasAny(['isTyping']) || data.isTyping is bool);
    }

    // --- Matches ---
    
    // Global rule for presence (Relaxed slightly for debugging/resilience)
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && isValidPresence(incoming());
    }

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(messageId) && isValidChatMessage(incoming());
      allow delete: if isSignedIn() && (request.auth.uid == existing().userId || isAdmin());
      allow update: if isAdmin();
    }

    match /dailyRecords/{recordId} {
      // Allowing public read for the dashboard data
      allow read: if true;
      allow create: if isSignedIn() && isValidId(recordId) && isValidDailyRecord(incoming());
      allow update: if isSignedIn() && isValidId(recordId) && isValidDailyRecord(incoming());
      allow delete: if isAdmin();
    }
    
    match /system_updates/{updateId} {
      allow read: if true; // Publicly readable for initial banner loading
      allow write: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    match /test/connection {
      allow get: if true;
    }
  }
}
