rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /chat/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && request.resource.contentType.matches('image/.*|video/.*|application/.*');
    }
  }
}
